# =============================================================================
# LicitAnalytics — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=3000

# URL permitida no CORS (origem do frontend)
FRONTEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/licit_analytics?schema=public"

# -----------------------------------------------------------------------------
# Cache & Filas (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Autenticação JWT
# Gere um segredo forte: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_FORTE_DE_64_BYTES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Portal da Transparência (API pública)
# Obtenha sua chave em: https://api.portaldatransparencia.gov.br/
# -----------------------------------------------------------------------------
TRANSPARENCY_API_KEY=sua_chave_aqui
TRANSPARENCY_API_URL=https://api.portaldatransparencia.gov.br
