generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoDespesa {
  EMPENHO
  LIQUIDACAO
  PAGAMENTO
}

enum OsStatus {
  AGUARDANDO
  FATURADO
  PAGO
}

model Company {
  id        String     @id @default(uuid())
  cnpj      String     @unique @db.VarChar(14)
  name      String
  expenses  Expense[]
  contracts Contract[]
  grants     Grant[]    // Convênios
  amendments Amendment[] // Emendas
  
  @@map("companies")
}

model Expense {
  id              String         @id @default(uuid())
  companyId       String
  numeroDocumento String         // Ex: 2026NE0000503
  orgao           String         // Ex: SEDUC

  // --- Campos da API Pública ---
  orgaoSuperior   String?        @db.VarChar(255)
  unidadeGestora  String?        @db.VarChar(255)
  tipo            TipoDespesa    @default(EMPENHO)
  descricao       String         @db.Text
  numeroProcesso  String?        @db.VarChar(100)
  elementoDespesa String?        @db.VarChar(255)

  // Valor público mapeado para "valorOriginal" (Teto do Empenho)
  valorOriginal   Decimal        @db.Decimal(15, 2)

  // --- Campos do ERP Interno ---
  recurso         String?        // Ex: CAPITAL, INTERIOR
  competencia     String?        // Ex: JANEIRO/MARÇO
  valorFaturado   Decimal        @default(0) @db.Decimal(15, 2)
  saldo           Decimal        @default(0) @db.Decimal(15, 2)

  data            DateTime
  createdAt       DateTime       @default(now())

  // Vínculo com Contrato (correlacionado via numeroProcesso ou importação)
  contractId      String?
  contract        Contract?      @relation(fields: [contractId], references: [id])

  // Relacionamentos
  company         Company        @relation(fields: [companyId], references: [id])
  ordensServico   ServiceOrder[]

  @@index([contractId])
  @@index([companyId, tipo])
  @@index([numeroProcesso])
  @@map("expenses")
}

model Contract {
  id                 String    @id @default(uuid())
  companyId          String
  numero             String    @db.VarChar(100)
  objeto             String    @db.Text
  dataAssinatura     DateTime?
  dataInicioVigencia DateTime?
  dataFimVigencia    DateTime?
  valorInicial       Decimal   @db.Decimal(15, 2)
  valorFinal         Decimal   @db.Decimal(15, 2)
  situacao           String    @db.VarChar(100)
  unidadeGestora     String    @db.VarChar(255)
  orgaoSuperior      String?   @db.VarChar(255)

  company            Company   @relation(fields: [companyId], references: [id])
  expenses           Expense[] // Empenhos, liquidações e pagamentos vinculados

  @@index([companyId])
  @@map("contracts")
}

model ServiceOrder {
  id            String    @id @default(uuid())
  expenseId     String    // Vinculado à Nota de Empenho
  numeroOS      String    @db.VarChar(50)  // Ex: 022/2026
  unidade       String    @db.VarChar(255) // Ex: EE ADELAIDE TAVARES
  dataExecucao  DateTime
  quantidade    Int       // Ex: 44 (máquinas)
  descricao     String?   @db.Text         // Ex: CAPITAL, CDE 03
  executante    String?   @db.VarChar(100) // Ex: THERMAL
  
  // Financeiro da O.S.
  custo         Decimal   @db.Decimal(15, 2) // O que custou à empresa
  valorFinal    Decimal   @db.Decimal(15, 2) // O que será cobrado (Vf)
  margem        Decimal   @db.Decimal(5, 4)  // Margem de lucro (Ex: 0.0961)
  
  // Controle de Status
  status        OsStatus  @default(AGUARDANDO) // Enum
  competencia   String?   @db.VarChar(50)    // Ex: JANEIRO
  numeroNF      String?   @db.VarChar(100)   // Nota Fiscal (se já faturado)
  
  // Relacionamentos
  expense       Expense   @relation(fields: [expenseId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("service_orders")
}

model Amendment {
  id         String   @id @default(uuid())
  externalId String   @unique
  companyId  String
  author     String   // Parlamentar
  year       Int
  value      Decimal  @db.Decimal(18, 2)
  company    Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("amendments")
}

model Grant {
  id          String   @id @default(uuid())
  externalId  String   @unique // Número do convênio
  companyId   String
  object      String   @db.Text
  valueGlobal Decimal  @db.Decimal(18, 2)
  status      String
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("grants")
}